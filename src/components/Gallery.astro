---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { generateRuggedRectangle } from "@lib/utils";
import { useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

type WorkImage = CollectionEntry<"works">["data"]["image"];

interface Props {
  images: WorkImage[];
  locale?: Lang;
}

const { images, locale = "it" } = Astro.props;
const t = useTranslations(locale);

const imageData = images.map((img) => ({
  src: img.src,
  width: img.width,
  height: img.height,
}));

const galleryCount = images.length - 1;
const gallerySuffix = galleryCount === 1 ? "e" : "i";
---

{
  images.length >= 2 && (
    <p
      class="border border-foreground rounded-md text-center mt-8 w-fit mx-auto py-1 px-4 text-sm md:hidden"
      set:html={t("portfolio.galleryScroll", {
        count: `<b>${galleryCount}</b>`,
        suffix: gallerySuffix,
      })}
    />
  )
}

<ul
  role="group"
  id="gallery"
  aria-label="galleria di immagini legate al progetto"
  class="w-full p-2 md:p-4 mx-auto snap-proximity snap-always snap-x flex flex-row flex-nowrap overflow-x-scroll md:block md:columns-2 md:mt-24"
>
  {
    images.map((image, index) => (
      <li class="snap-center m-1 md:my-4 md:first:mt-12 md:mx-0 block min-w-fit">
        <button class="open-lightbox cursor-pointer" data-imageid={index}>
          <Image
            class="object-contain w-full"
            loading="lazy"
            src={image}
            height={image.height}
            width={image.width}
            alt=""
            style={`
                        aspect-ratio: ${image.width}/${image.height};
                        clip-path:${generateRuggedRectangle({
                          points: 9,
                          roughness: 1.1,
                          seed: index * 3 + 1367843912,
                          spikes: false,
                        })};
                        `}
            data-index={index}
          />
        </button>
      </li>
    ))
  }
</ul>

<div
  role="dialog"
  aria-modal="false"
  class="hidden fixed z-50 top-0 left-0 w-screen h-screen items-center justify-center p-4 bg-foreground/90"
  id="lightbox"
  data-gallery={JSON.stringify(imageData)}
  data-currentid="0"
>
  <button
    autofocus
    class="bg-background focus:bg-accent p-2 fixed top-5 right-5 font-sans text-lg font-bold text-foreground leading-none z-40 min-w-12 min-h-12"
    id="close-lightbox"
    aria-label="chiudi galleria">&times;</button
  >
  <img
    id="lightbox-image"
    src={imageData[0].src}
    alt=""
    class="mx-auto max-h-[96dvh] max-w-[90vw] w-full object-contain"
    height={imageData[0].height}
    width={imageData[0].width}
  />
  <div
    role="navigation"
    class="fixed flex justify-between items-center w-full mb-5 gap-5 p-5 h-full"
  >
    <button
      class="font-sans text-lg font-bold h-full min-w-12"
      id="prev-lightbox"
      aria-label="immagine precedente"
    >
      <span class="bg-foreground/50 p-2 text-white">&larr;</span>
    </button>
    <button
      class="font-sans text-lg font-bold h-full min-w-12"
      id="next-lightbox"
      aria-label="prossima immagine"
    >
      <span class="bg-foreground/50 p-2 text-white">&rarr;</span>
    </button>
  </div>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const lightbox: HTMLElement = document.querySelector("#lightbox")!;
  const lightbox_image: HTMLImageElement =
    document.querySelector("#lightbox-image")!;
  const IMAGES = JSON.parse(lightbox.dataset.gallery!);

  function lightbox_listener(e: KeyboardEvent) {
    if (e.code === "Escape") {
      lightbox_close();
    }
    if (e.code === "ArrowLeft") {
      lightbox_prevSlide();
    }
    if (e.code === "ArrowRight") {
      lightbox_nextSlide();
    }
  }

  function lightbox_close() {
    lightbox.classList.remove("flex");
    lightbox.classList.add("hidden");
    lightbox.ariaModal = "false";
    document.removeEventListener("keydown", lightbox_listener);
  }

  function lightbox_open() {
    lightbox.classList.add("flex");
    lightbox.classList.remove("hidden");
    lightbox.ariaModal = "true";
    document.addEventListener("keydown", lightbox_listener);
  }

  function lightbox_setImage(index: number) {
    lightbox.dataset.currentid = index.toString();
    lightbox_image.src = IMAGES[index].src;
    lightbox_image.height = IMAGES[index].height;
    lightbox_image.width = IMAGES[index].width;
  }

  function lightbox_nextSlide() {
    let index = parseInt(lightbox.dataset.currentid!) + 1;
    if (index >= IMAGES.length) {
      index = 0;
    }
    lightbox_setImage(index);
  }

  function lightbox_prevSlide() {
    let index = parseInt(lightbox.dataset.currentid!) - 1;
    if (index < 0) {
      index = IMAGES.length - 1;
    }
    lightbox_setImage(index);
  }

  let isDragging = false;

  ScrollTrigger.observe({
    target: "#lightbox",
    type: "touch",
    dragMinimum: 20,
    preventDefault: true,
    onDragStart: () => (isDragging = true),
    onLeft: () => {
      isDragging && lightbox_prevSlide();
      isDragging = false;
    },
    onRight: () => {
      isDragging && lightbox_nextSlide();
      isDragging = false;
    },
  });

  document.querySelectorAll("button.open-lightbox").forEach(
    (btn) =>
      btn instanceof HTMLElement &&
      btn.addEventListener("click", () => {
        const index = parseInt(btn.dataset.imageid!);
        lightbox_open();
        lightbox_setImage(index);
      }),
  );

  lightbox
    .querySelector("#close-lightbox")
    ?.addEventListener("click", lightbox_close);
  lightbox
    .querySelector("#next-lightbox")
    ?.addEventListener("click", lightbox_nextSlide);
  lightbox
    .querySelector("#prev-lightbox")
    ?.addEventListener("click", lightbox_prevSlide);
</script>
