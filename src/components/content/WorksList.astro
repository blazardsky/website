---
import { getCollection } from "astro:content";
import { type Portfolio } from "@lib/types";
import { cn, generateRuggedRectangle } from "@lib/utils";
import { getWorksForLocale, localizedUrl, useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { Image } from "astro:assets";

interface Props {
  portfolio: Portfolio;
}

const { portfolio } = Astro.props;
const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const entries = await getCollection("works");
const works = getWorksForLocale(entries, locale, portfolio);
---

<ul class="grid grid-flow-row -mt-10 mx-4 gap-12">
  {
    works.map((work, index) => (
      <li
        class={cn(
          "work-card",
          "flex flex-col gap-4 md:items-center p-6 ease-in-out duration-150",
          index % 2 === 0
            ? "md:flex-row md:-rotate-1"
            : "md:flex-row-reverse md:rotate-1",
          portfolio === "creative" && "bg-creative-light",
          portfolio === "technical" && "bg-technical-light",
          "hover:rotate-0",
        )}
        style={`clip-path:${generateRuggedRectangle({
          points: 60,
          roughness: 1.2,
          seed: (index + 1) * 9092,
          spikes: false,
        })};`}
      >
        <Image
          src={work.data.image}
          height={work.data.image.height / 2}
          width={work.data.image.width / 2}
          loading={index === 0 ? "eager" : "lazy"}
          alt={`Immagine di anteprima del lavoro ${work.data.title}`}
          class="w-full md:max-w-[56vw]"
          style={`aspect-ratio: 16/12; clip-path:${generateRuggedRectangle({
            points: 20,
            roughness: 1.2,
            seed: index * 33,
          })};`}
        />

        <div class="w-full h-full grow flex flex-col md:max-w-md mx-auto p-2 md:p-8 lg:p-12">
          <p class={cn("font-sm uppercase font-medium", "mt-auto")}>
            {work.data.start_date.getFullYear()}/{work.data.client}
          </p>
          <h3 class="uppercase font-extrabold text-4xl leading-none gsap-split-word">
            {work.data.title}
          </h3>
          <p class="mt-2 font-cursive">
            {(work.body ?? "").slice(0, 120)}&hellip;
          </p>
          <a
            href={localizedUrl(
              locale,
              `portfolio/${portfolio}/${work.data.slug}`,
            )}
            class={cn(
              portfolio === "creative" &&
                "bg-creative text-orange-950 active:bg-creative-dark",
              portfolio === "technical" &&
                "bg-technical text-purple-950 active:bg-technical-dark",
              "px-8 py-2 text-center mt-6 mb-0 block uppercase font-bold tracking-wide hover:shadow-sm hover:scale-105 active:scale-95 transition-all ease-in-out duration-300",
              "mb-auto",
            )}
            style={`clip-path:${generateRuggedRectangle({
              points: 8,
              roughness: 1.1,
              seed: (index + 1) * 3,
              spikes: true,
            })};`}
          >
            {t("portfolio.readMore")}
          </a>
        </div>
      </li>
    ))
  }
</ul>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const cards = gsap.utils.toArray<HTMLElement>(".work-card");

  cards.forEach((card) => {
    gsap.fromTo(
      card,
      {
        y: 100,
      },
      {
        duration: 0.1,
        y: 0,
        stagger: 0.15,
        ease: "elastic",
        scrollTrigger: card,
      },
    );
    gsap.fromTo(
      card.querySelector("img"),
      {
        y: 100,
        opacity: 0,
      },
      {
        delay: 0.5,
        duration: 0.5,
        opacity: 1,
        y: 0,
        stagger: 0.15,
        ease: "ease",
        scrollTrigger: card,
      },
    );
  });
</script>
