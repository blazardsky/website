---
import Menu from "@components/globals/Menu.astro";
import AccessibilityIcon from "@svg/accessibility.svg?raw";

import { isMenuOpen } from "@lib/store";
import { useTranslations, localizedUrl, getLocaleSwitchUrl } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

const menuIsOpen = isMenuOpen.get();
const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);
const localeSwitchUrl = getLocaleSwitchUrl(Astro.url.pathname, locale);
const homeUrl = localizedUrl(locale, "");
---

<header class="flex flex-row z-50 relative">
  {
    Astro.url.pathname !== homeUrl && Astro.url.pathname !== `${homeUrl}/` && (
      <a class="px-4 " href={homeUrl}>
        <span class="border-foreground border-b-2 border-x-2 min-h-11 grid place-items-center text-foreground py-1 px-4 md:px-8 font-extrabold text-base uppercase transition-all ease-out hover:scale-y-110 origin-top">
          {t("nav.home")}
        </span>
      </a>
    )
  }
  <div class="w-full flex justify-end px-4">
    <ul role="menu" class="flex flex-row gap-1">
      <li role="menuitem">
        <button
          onclick="toggleReadabilityImprovement()"
          title={t("nav.accessibility.title")}
          class="border-foreground grid place-items-center cursor-pointer border-b-2 min-h-11 border-x-2 bg-foreground fill-background p-1 transition-all ease-out hover:scale-y-110 origin-top m-0 focus:border-accent"
        >
          <span class="sr-only">{t("nav.accessibility")}</span>
          <Fragment set:html={AccessibilityIcon} />
        </button>
      </li>
      <li role="menuitem">
        <a
          aria-label={t("lang.switch.aria")}
          title={t("lang.switch.title")}
          href={localeSwitchUrl}
          class="grid place-items-center no-underline border-foreground border-b-2 min-h-11 border-x-2 bg-foreground text-background p-1 font-extrabold text-base uppercase transition-all ease-out hover:scale-y-110 origin-top m-0"
        >
          <abbr class="decoration-accent decoration-dotted" title={t("lang.switch.title")}
            >{t("lang.switch")}</abbr
          >
        </a>
      </li>
      <li role="menuitem">
        <button
          id="toggleMenu"
          aria-controls="menu"
          aria-label={menuIsOpen ? t("nav.menu.close") : t("nav.menu.open")}
          data-label-open={t("nav.menu")}
          data-label-close={t("nav.close")}
          class="border-foreground cursor-pointer border-b-2 min-h-11 border-x-2 bg-foreground text-background p-1 px-4 md:px-8 font-extrabold text-base uppercase block transition-all ease-out hover:scale-y-110 origin-top m-0"
        >
          {t("nav.menu")}
        </button>
      </li>
    </ul>
  </div>
</header>
<Menu />

<script>
  import { isMenuOpen } from "@lib/store.ts";

  const menuBtn = document.getElementById("toggleMenu")!;

  function toggleMenu() {
    const nextMenuState = !isMenuOpen.get();
    menuBtn.innerHTML = nextMenuState
      ? menuBtn.dataset.labelClose!
      : menuBtn.dataset.labelOpen!;
    isMenuOpen.set(nextMenuState);
  }
  menuBtn.addEventListener("click", toggleMenu);
</script>

<script is:inline>
  const readabilityStyle = new CSSStyleSheet();
  readabilityStyle.replaceSync(
    ".font-cursive { font-family: monospace !important; font-size: 105% !important; }",
  );

  let improveReadability = "off"; //di base è "spento"

  if (
    typeof localStorage !== "undefined" &&
    localStorage.getItem("improveReadability")
  ) {
    improveReadability = localStorage.getItem("improveReadability");
    setReadabilityImprovement(); //avvio il toggle a ogni pagina in base al local storage precedente
  }

  function toggleReadabilityImprovement() {
    improveReadability = improveReadability === "off" ? "on" : "off"; // faccio il toggle
    localStorage.setItem("improveReadability", improveReadability);
    setReadabilityImprovement(); //attivo o disattivo
  }

  function setReadabilityImprovement() {
    if (improveReadability === "on") {
      document.adoptedStyleSheets = [readabilityStyle];
    } else {
      document.adoptedStyleSheets = [];
    }
  }
</script>
