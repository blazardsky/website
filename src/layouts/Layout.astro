---
interface Props {
    title: string;
    description?: string;
    bodyClass?: string;
}
const { title, description, bodyClass } = Astro.props;

import { cn } from "@lib/utils";
import Header from "@components/globals/Header.astro";
import Footer from "@components/globals/Footer.astro";
import NicPlayer from "@components/globals/NicPlayer.astro";
import CookieNotice from "@components/CookieNotice.astro";

import "../styles/global.css";

// importo le svg che uso come clip-path per i BigPortfolioButton e per le sezioni colorate e in altri posti nel sito
import clip01 from "@svg/PortfolioClip_01.svg?raw";
import clip02 from "@svg/PortfolioClip_02.svg?raw";
---

<!doctype html>
<html lang="it" prefix="og: https://ogp.me/ns#">
    <head>
        <meta charset="utf-8" />
        <meta
            name="description"
            content={description
                ? description
                : "Portfolio - Niccolò Agnoletti: web developer + designer + digital illustrator."}
        />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link
            href="https://api.fontshare.com/v2/css?f[]=clash-display@1&f[]=kalam@400&display=swap"
            rel="stylesheet"
        />
        <meta name="author" content="Niccolò Agnoletti" />
        <meta property="og:locale" content="it_IT" />
        <meta
            property="og:title"
            content="Web Developer, Designer and Digital Illustrator - Niccolò Agnoletti"
        />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://www.nicc-olo.com" />
        <meta
            property="og:image"
            content="https://www.nicc-olo.com/nicc-olo.com_social-share-thumbnail.jpg/"
        />
        <meta property="og:image:type" content="image/jpeg" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta
            property="og:image:alt"
            content="Un illustrazione di un omino giallo con una cresta lilla davanti al pc che indica le scritte Web Development, (handmande) digital illustrations, editorial design"
        />

        <script
            is:inline
            type="text/partytown"
            defer
            src="https://cloud.umami.is/script.js"
            data-website-id="1ee9f997-2d04-4991-b78c-aa70ff93efe4"></script>
    </head>
    <body
        class={cn(
            "overscroll-y-contain bg-background text-foreground",
            bodyClass,
        )}
    >
        <Header />
        <slot />
        <Footer>
            <NicPlayer bodyClass={bodyClass} />
        </Footer>

        <CookieNotice />

        <!-- clip path svg per portfolio e blocchi vari -->
        <Fragment set:html={clip01} />
        <Fragment set:html={clip02} />
    </body>
</html>

<style is:global>
    /* nascondo i testi gsap finché non sono animati */
    [class*="gsap-split-"] {
        visibility: hidden;
    }
</style>
<script>
    import { gsap } from "gsap";
    import { SplitText } from "gsap/SplitText";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(SplitText, ScrollTrigger);

    const splitChars = gsap.utils.toArray<HTMLElement>(".gsap-split-char");
    const splitWords = gsap.utils.toArray<HTMLElement>(".gsap-split-word");
    const splitLines = gsap.utils.toArray<HTMLElement>(".gsap-split-line");

    function splitForEach(
        split_elements: HTMLElement[],
        split_what: string,
        mask_what: "lines" | "words" | "chars",
    ) {
        split_elements.forEach((split_elem) => {
            gsap.set(split_elem, { autoAlpha: 1 });
            SplitText.create(split_elem, {
                type: split_what,
                mask: mask_what,
                autoSplit: true,
                onSplit(self) {
                    return gsap.from(self[mask_what], {
                        duration: 0.6,
                        y: 100,
                        autoAlpha: 0.7,
                        scrollTrigger: split_elem,
                        stagger: {
                            amount: 0.4,
                        },
                    });
                },
            });
        });
    }

    splitForEach(splitChars, "lines, words, chars", "chars");
    splitForEach(splitWords, "lines, words", "words");
    splitForEach(splitLines, "lines", "lines");
</script>
