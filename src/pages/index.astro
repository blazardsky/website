---
import Layout from "@layouts/Layout.astro";
import PortfolioButtons from "@components/PortfolioButtons.astro";
import Testimonal from "@components/Testimonal.astro";
import Certificate from "@components/content/Certificate.astro";
import CardIcon from "@components/CardIcon.astro";
import BigPortfolioButton from "@components/BigPortfolioButton.astro";
import INDEX from "@data/index.json";
import SOCIALS from "@data/socials.json";
import { Image } from "astro:assets";
import ImmersiveWorks from "@components/ImmersiveWorks.astro";
import FollowTheLine from "@components/FollowTheLine.astro";
import AnimatedIllustration from "@components/AnimatedIllustration.astro";
import { pickLocale, localizedUrl } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import type { LocalizedData } from "@i18n/utils";
import type { IndexPageData } from "@lib/types";

import clipHome from "@svg/PortfolioClip_home.svg?raw";

const locale = Astro.currentLocale as Lang;
const page = pickLocale(INDEX as LocalizedData<IndexPageData>, locale);
---

<Layout title={page.meta.title}>
  <main class="intro-container-title">
    <h1
      class="uppercase font-extrabold leading-none intro-large-title p-2 md:p-4 m-auto gsap-split-line"
      set:html={page.hero.heading}
    />
    <ul
      class="flex flex-col sm:flex-row gap-4 md:gap-0 mt-8 sm:mt-16 w-full overflow-x-clip md:px-3"
    >
      <BigPortfolioButton
        href={localizedUrl(locale, "portfolio/technical")}
        title={page.hero.technical.title}
        src="/assets/images/punkwebdev.png"
        type="technical"
        ariaLabel={page.hero.technical.ariaLabel}
      >
        <Fragment set:html={page.hero.technical.content} />
      </BigPortfolioButton>
      <BigPortfolioButton
        href={localizedUrl(locale, "portfolio/creative")}
        title={page.hero.creative.title}
        src="/assets/images/creativecat.png"
        type="creative"
        ariaLabel={page.hero.creative.ariaLabel}
      >
        <Fragment set:html={page.hero.creative.content} />
      </BigPortfolioButton>
    </ul>
  </main>
  <section class="bg-accent px-4 py-24 mt-2 clip01">
    <h2
      class="text-center font-extrabold uppercase text-4xl md:text-6xl text-pretty gsap-split-word"
      set:html={page.about.heading}
    />
    <div
      class="flex flex-col sm:flex-row mt-8 md:gap-12 mx-auto max-w-5xl items-center"
    >
      <Image
        src="/assets/images/weirdnic.png"
        height="200"
        width="200"
        alt={page.about.alt}
        class="w-auto max-w-md h-auto max-h-[60vh] md:max-h-[auto]"
      />
      <div class="drop-shadow-md">
        <div
          class="bg-white/50 p-8 sm:p-12 w-fit h-fit text-xl font-cursive rotate-1"
          style="clip-path: polygon(18% 1%, 36% 0, 49% 2%, 55% 1%, 88% 2%, 99% 1%, 100% 42%, 99% 55%, 100% 76%, 99% 88%, 99% 98%, 82% 100%, 36% 99%, 17% 100%, 4% 98%, 1% 91%, 1% 55%, 0% 44%, 1% 29%, 1% 2%);"
        >
          <p>{page.about.introLabel}</p>
          <p class="mt-2" set:html={page.about.p1} />
          <p class="mt-2">
            {page.about.p2Before}
            <a
              href="https://www.dafont.com/it/blazardsky.d6835"
              target="_blank"
              rel="noopener"
              class="underline"
            >
              {page.about.p2FontLink}
            </a>
            {page.about.p2After}
            <a href={localizedUrl(locale, "projects")}>{page.about.p2ProjectsLink}</a>
          </p>
        </div>
      </div>
    </div>
  </section>
  <PortfolioButtons />
  <section class="bg-foreground text-background px-4 py-24 clipHome">
    <h2
      class="text-center font-light uppercase text-4xl md:text-6xl mt-24 gsap-split-word"
      set:html={page.scroll.heading}
    />
    <FollowTheLine color="#F7F6DF77" />
    <h3
      class="text-center font-extrabold uppercase text-4xl md:text-5xl mt-12 gsap-split-word"
    >
      {page.whyWork.heading}
    </h3>
    <ul class="my-12 flex flex-col md:flex-row max-w-6xl mx-auto gap-4">
      {
        page.whyWork.cards.map((card) => (
          <CardIcon
            title={card.title}
            titleLang={card.titleLang}
            body={card.body}
            icon={card.icon}
            class={card.class}
          />
        ))
      }
    </ul>
    <h3
      class="text-center font-extrabold uppercase text-xl md:text-4xl mt-52 gsap-split-word"
    >
      {page.testimonials.heading}
    </h3>
    <ul class="group list-none p-2 w-fit mx-auto">
      {
        page.testimonials.items.map((testimonial, index) => (
          <Testimonal
            id={testimonial.id}
            name={testimonial.by}
            role={testimonial.role}
            body={testimonial.body}
            src={testimonial.img}
            link={testimonial.link}
            isLast={index + 1 === page.testimonials.items.length}
          />
        ))
      }
    </ul>
  </section>
  <div class="px-4 my-24">
    <h3
      class="text-center font-extrabold uppercase text-3xl md:text-5xl mt-36 gsap-split-word"
    >
      {page.skills.heading}
    </h3>
    <p class="text-sm text-center">
      {page.skills.linkPrefix}
      <a href={localizedUrl(locale, "skills")}>{page.skills.linkText}</a>.
    </p>
    <div class="mx-auto max-w-4xl my-12 p-4">
      <span class="bg-technical rounded-md p-1 uppercase font-bold"
        >{page.skills.tech.label}</span
      >
      <h4
        class="mt-1 uppercase text-4xl mb-2 gsap-split-line"
        set:html={page.skills.tech.heading}
      />
      <p
        class="font-cursive text-lg text-balance"
        set:html={page.skills.tech.body}
      />
    </div>
    <div class="block w-full max-w-5xl mx-auto p-2">
      <AnimatedIllustration />
    </div>
    <div class="mx-auto max-w-4xl my-12 p-4">
      <span
        lang="en"
        class="bg-creative rounded-md p-1 uppercase font-bold"
        >{page.skills.creative.label}</span
      >
      <h4
        class="mt-1 mb-2 uppercase text-4xl gsap-split-line"
        set:html={page.skills.creative.heading}
      />
      <p
        class="font-cursive text-lg text-balance"
        set:html={page.skills.creative.body}
      />
    </div>

    <div class="mx-auto max-w-4xl my-12 flex flex-col sm:flex-row">
      <p class="uppercase opacity-70 px-4">
        {page.skills.socialHint}
        <a
          href={SOCIALS[2].link}
          target="_blank"
          rel="noopener"
          title={`apri ${SOCIALS[2].name} in una nuova scheda`}
          class="underline">{SOCIALS[2].name} &UpperRightArrow;</a
        ><br />
      </p>
      <Image
        src="/assets/images/fiorellini.png"
        alt=""
        height="190"
        width="190"
      />
    </div>
  </div>

  <section class="px-4 py-36">
    <div>
      <h3
        class="text-3xl md:text-4xl xl:text-5xl text-center font-extrabold uppercase gsap-split-word"
      >
        {page.certificates.heading}
      </h3>
      <ul
        class="mx-auto p-6 grid grid-flow-row sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-9 my-12 text-center"
      >
        {
          page.certificates.items.map((certificate, index) => (
            <Certificate data={certificate} index={index} />
          ))
        }
      </ul>
    </div>
  </section>

  <ImmersiveWorks />

  <PortfolioButtons before_title={page.portfolioCta.beforeTitle} />

  <section>
    <FollowTheLine />

    <h3 class="uppercase font-extrabold text-center gsap-split-word">
      {page.contact.heading}
    </h3>
    <Image
      src="/assets/images/scimmietta.png"
      alt={page.contact.ctaAlt}
      class="mx-auto max-w-64"
      height="254"
      width="375"
    />
    <div
      class="mt-24 md:mt-64 mx-auto max-w-[94vw] md:max-w-3xl text-3xl md:text-5xl relative"
      id="cta_lavoro"
    >
      <div
        class="p-8 md:px-12 md:pt-12 pb-20 mb-28 bg-midground -rotate-2 has-[a:hover]:rotate-2 will-change-transform transition-transform ease-out"
        style="clip-path: polygon(2% 1%, 0% 5%, 12% 2%, 18% 0%, 25% 1%, 32% 0%, 38% 2%, 51% 2%, 48% 0%, 59% 0%, 56% 1%, 69% 1%, 67% 0%, 80% 0%, 83% 1%, 87% 0%, 91% 2%, 94% 1%, 99% 0%, 100% 8%, 100% 14%, 99% 19%, 100% 24%, 99% 30%, 100% 36%, 100% 49%, 98% 47%, 100% 57%, 100% 64%, 99% 66%, 100% 71%, 98% 84%, 100% 87%, 100% 95%, 98% 100%, 80% 100%, 86% 99%, 69% 99%, 64% 100%, 55% 99%, 50% 100%, 39% 94%, 43% 100%, 36% 99%, 29% 100%, 24% 98%, 15% 100%, 9% 100%, 4% 100%, 1% 98%, 5% 90%, 1% 83%, 2% 69%, 0% 62%, 1% 44%, 0% 32%, 2% 23%, 0% 12%, 4% 12%, 0% 4%);"
      >
        <p class="uppercase font-extrabold text-left">
          {page.contact.ctaBefore}
          <a href="mailto:ciao@nicc-olo.com" class="underline"
            >{page.contact.ctaLink}</a
          >
        </p>
      </div>
      <svg
        aria-hidden="true"
        class="absolute -bottom-28 left-[8ch]"
        width="117"
        height="167"
        viewBox="0 0 117 167"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M48.1235 3.05025C54.8442 16.5497 61.8563 29.937 68.2074 43.6155C74.4595 57.0808 77.335 71.0454 78.4731 86.0738C79.3926 98.2164 79.4842 107.647 78.4368 119.934C77.1724 134.766 72.8408 148.483 69.584 163.076"
          stroke="#222222"
          stroke-width="5"
          stroke-linecap="round"></path>
        <path
          d="M68.9448 163.571C66.8524 159.369 64.7601 155.166 62.6677 150.963C61.5196 148.657 60.6063 146.152 58.4967 144.507"
          stroke="#222222"
          stroke-width="5"
          stroke-linecap="round"></path>
        <path
          d="M69.656 164.36C73.0322 162.679 76.0629 161.169 78.9082 158.675C82.0364 155.933 84.6013 152.79 87.197 149.632"
          stroke="#222222"
          stroke-width="5"
          stroke-linecap="round"></path>
      </svg>
    </div>
    <p class="font-cursive max-w-sm mx-auto px-8 text-pretty text-center">
      {page.contact.note}
    </p>
  </section>

  <Fragment set:html={clipHome} />
</Layout>

<style>
  .clipHome {
    clip-path: url(#containerClipHome);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    "#cta_lavoro",
    {
      scale: 0.8,
      opacity: 0.75,
      rotate: "-2deg",
    },
    {
      scale: 1,
      opacity: 1,
      rotate: 0,
      delay: 0.5,
      duration: 0.35,
      ease: "ease",
      scrollTrigger: "#cta_lavoro",
    },
  );
</script>
