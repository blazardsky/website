---
import Layout from "@layouts/Layout.astro";
import Work from "@components/content/WorksList.astro";
import PORTFOLIO from "@data/portfolio.json";
import { type Portfolio } from "@lib/types.ts";
import { pickLocale } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import type { LocalizedData } from "@i18n/utils";
import type { PortfolioPageData } from "@lib/types";

export function getStaticPaths() {
    return [
        { params: { portfolioType: "technical" } },
        { params: { portfolioType: "creative" } },
    ];
}

const portfolioType = Astro.params.portfolioType as Portfolio;
const locale = Astro.currentLocale as Lang;
const portfolioData = pickLocale(
    PORTFOLIO as LocalizedData<PortfolioPageData>,
    locale,
);
const DATA = portfolioData[portfolioType];
---

<Layout
    title={`Niccolò Agnoletti - ${portfolioType} portfolio`}
    bodyClass={DATA.bodyClass}
>
    <section
        class="w-full bg-no-repeat bg-contain min-h-96 flex items-center z-10 relative"
        style={DATA.style}
    >
        <div class="text-center w-full mx-auto p-4">
            <h1 class="font-cursive">{DATA.title}</h1>
            <p
                class="leading-none text-2xl gsap-split-word"
                set:html={DATA.subtitle}
            />
        </div>
    </section>
    <main>
        <Work portfolio={portfolioType} />
    </main>
</Layout>
