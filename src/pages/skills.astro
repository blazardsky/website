---
import Layout from "@layouts/Layout.astro";
import SKILLS from "@data/skills.json";
import { pickLocale } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import type { LocalizedData } from "@i18n/utils";
import type { SkillsPageData } from "@lib/types";

const locale = Astro.currentLocale as Lang;
const page = pickLocale(SKILLS as LocalizedData<SkillsPageData>, locale);
---

<Layout title={page.meta.title} description={page.meta.description}>
    <main class="mx-auto p-4 max-w-3xl">
        <h1 class="my-20 uppercase font-extrabold text-4xl md:text-6xl">
            {page.meta.heading}
        </h1>
        <div class="grid gap-8">
            {
                page.fields.map((field) => (
                    <section>
                        <h2
                            class="uppercase font-extrabold text-2xl px-2 rounded-md w-fit mb-2 gsap-split-word"
                            style={{
                                backgroundColor: `rgb(${field.meta.bg})`,
                                color: `rgb(${field.meta.color})`,
                            }}
                        >
                            {field.type}
                        </h2>
                        <ul class="flex flex-row gap-2 flex-wrap">
                            {field.skills.map((skill) => (
                                <li class="border rounded-md p-2 border-foreground font-cursive m-0">
                                    {skill}
                                </li>
                            ))}
                        </ul>
                    </section>
                ))
            }
        </div>
    </main>
</Layout>
