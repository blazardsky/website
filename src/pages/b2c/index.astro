---
import Layout from "@layouts/Layout.astro";
import BigPortfolioButton from "@components/BigPortfolioButton.astro";
import FollowTheLine from "@components/FollowTheLine.astro";
---

<Layout
  title="Niccolò Agnoletti — Siti web per creativi"
  description="Siti web, gallerie e shop per musicisti e artisti visivi. Pacchetti su misura per band, DJ, illustratori, fotografi e designer."
>
  <main class="intro-container-title px-4">
    <h1
      class="uppercase font-extrabold leading-none intro-large-title p-2 md:p-4 m-auto gsap-split-line"
    >
      Siti web per chi fa <strong>musica</strong> e per chi fa <strong>arte</strong>
    </h1>
    <p class="font-cursive text-lg text-center max-w-3xl mx-auto mt-8 text-balance">
      Non sono un'agenzia generica: lavoro con creativi che hanno bisogno di una
      presenza online chiara — un sito che racconta chi sei, mostra il tuo lavoro
      e, se serve, vende merch o biglietti.
    </p>
  </main>

  <section class="px-4 py-16 md:py-24">
    <h2
      class="text-center font-extrabold uppercase text-3xl md:text-5xl gsap-split-word"
    >
      Per chi lavoro
    </h2>
    <ul
      class="flex flex-col sm:flex-row gap-4 md:gap-0 mt-8 sm:mt-16 w-full overflow-x-clip md:px-3 max-w-6xl mx-auto"
    >
      <BigPortfolioButton
        href="/b2c/musici"
        title="Musica"
        src="/assets/images/punkwebdev.png"
        type="technical"
        ariaLabel="Siti web per band, DJ e musicisti"
      >
        <strong>BAND, DJ</strong> &amp;<br />
        <strong>MUSICISTI</strong>
      </BigPortfolioButton>
      <BigPortfolioButton
        href="/b2c/artisti"
        title="Arte visiva"
        src="/assets/images/creativecat.png"
        type="creative"
        ariaLabel="Siti web per artisti visivi, illustratori e fotografi"
      >
        <strong>ILLUSTRATORI,</strong><br />
        <strong>FOTOGRAFI, DESIGNER…</strong>
      </BigPortfolioButton>
    </ul>
  </section>

  <section class="bg-accent px-4 py-24 clip01">
    <h2
      class="text-center font-extrabold uppercase text-3xl md:text-5xl text-pretty gsap-split-word"
    >
      Cosa posso costruire per te
    </h2>
    <ul
      class="max-w-4xl mx-auto mt-12 grid gap-4 md:grid-cols-3 text-center"
    >
      <li class="bg-white/50 p-6 clip03 rotate-1">
        <h3 class="uppercase font-bold text-xl">Sito web</h3>
        <p class="font-cursive mt-2">
          Homepage, bio, contatti, link ai social — tutto responsive e
          accessibile.
        </p>
      </li>
      <li class="bg-white/50 p-6 clip03 -rotate-1">
        <h3 class="uppercase font-bold text-xl">Contenuti dinamici</h3>
        <p class="font-cursive mt-2">
          Date del tour, galleria portfolio, news: aggiornabili da solo senza
          impazzire.
        </p>
      </li>
      <li class="bg-white/50 p-6 clip03 rotate-2">
        <h3 class="uppercase font-bold text-xl">Merch shop</h3>
        <p class="font-cursive mt-2">
          Integrazione con Shopify o soluzioni leggere per vendere stampe,
          magliette, zine.
        </p>
      </li>
    </ul>
  </section>

  <section class="px-4 py-24">
    <FollowTheLine />
    <div
      class="mt-16 mx-auto max-w-[94vw] md:max-w-3xl text-2xl md:text-4xl relative"
      id="cta_b2c"
    >
      <div
        class="p-8 md:px-12 md:pt-12 pb-16 mb-20 bg-midground -rotate-2 has-[a:hover]:rotate-2 will-change-transform transition-transform ease-out clip03"
      >
        <p class="uppercase font-extrabold text-left">
          Non sai da quale partire? <a
            href="mailto:ciao@nicc-olo.com?subject=Sito%20web%20per%20creativi"
            class="underline">Scrivimi</a
          > e ne parliamo.
        </p>
        <p class="font-cursive text-lg mt-4 normal-case">
          Raccontami cosa fai e ti indico il percorso giusto — musicisti o
          artisti visivi.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    "#cta_b2c",
    { scale: 0.9, opacity: 0.75, rotate: "-2deg" },
    {
      scale: 1,
      opacity: 1,
      rotate: 0,
      delay: 0.3,
      duration: 0.35,
      ease: "ease",
      scrollTrigger: "#cta_b2c",
    },
  );
</script>
