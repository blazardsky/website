{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@assets/*": ["src/assets/*"],
      "@layouts/*": ["src/layouts/*"],
      "@svg/*": ["src/assets/svg/*"],
      "@data/*": ["src/data/*"],
      "@lib/*": ["src/lib/*"],
      "@i18n/*": ["src/i18n/*"]
    },
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true
  }
}